# Database
DATABASE_URL="postgresql://sacms:Z0ngg0n4U@postgres:5432/sacms?pgbouncer=true"
DIRECT_URL="postgresql://sacms:Z0ngg0n4U@postgres:5432/sacms"
POSTGRES_PASSWORD="Z0ngg0n4U"

# ─── Self-Hosted Mode ──────────────────────────────
# Set to "true" to run SaCMS as a self-hosted single-tenant CMS
# This disables: landing page, SaaS billing, admin panel
# Only /dashboard/* routes and public APIs are active
SELFHOST_MODE="true"

# ─── Enterprise License (Self-Hosted) ──────────────
# Optional: Activate enterprise features (unlimited everything)
LICENSE_KEY=""
LICENSE_SERVER_URL="https://license.sacms.cloud"


# NextAuth
NEXTAUTH_SECRET="generate-a-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Email Delivery (Resend or SMTP)
RESEND_API_KEY=""
RESEND_FROM="SaCMS <noreply@sacms.local>"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_SECURE="false"
SMTP_FROM="SaCMS <noreply@sacms.local>"

# OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Redis (optional — falls back to in-memory)
REDIS_URL="redis://localhost:6379"

# Cloudflare R2 / S3 Storage
S3_ENDPOINT=""
S3_REGION="auto"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET=""
S3_PUBLIC_URL=""

# Payment Gateway (midtrans | stripe | xendit)
PAYMENT_PROVIDER="midtrans"

# Midtrans Payment
MIDTRANS_SERVER_KEY=""
MIDTRANS_CLIENT_KEY=""
MIDTRANS_IS_PRODUCTION="false"
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=""
NEXT_PUBLIC_MIDTRANS_SNAP_URL="https://app.sandbox.midtrans.com/snap/snap.js"

# Cron Jobs
CRON_SECRET="generate-a-cron-secret"

# OpenAI (optional — enables AI content generation)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Sentry Error Monitoring (optional)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

