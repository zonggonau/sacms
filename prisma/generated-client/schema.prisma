// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "./generated-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== USER & AUTH ====================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?
  image         String?
  role          String    @default("user") // super_admin, admin, user
  plan          String    @default("free") // free, standard, professional, business, unlimited
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts      Account[]
  sessions      Session[]
  tenants       TenantMember[]
  subscriptions Subscription[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ==================== TENANT ====================

model Tenant {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  logo        String?
  plan        String   @default("free") // free, starter, pro, enterprise
  status      String   @default("active") // active, suspended, deleted
  databaseUrl String? // Optional: External DB URL for Enterprise/Gov isolated data
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // ==================== WHITE-LABEL ====================
  customDomain           String?   @unique // e.g. api.myclient.com
  customDomainStatus     String? // pending, verified, failed
  customDomainVerifiedAt DateTime?
  brandName              String? // Override display name
  brandLogo              String? // Custom logo URL (overrides logo)
  primaryColor           String? // Hex color for branded UI e.g. #3B82F6
  customEmailSender      String? // e.g. "Acme CMS <noreply@acme.com>"
  faviconUrl             String? // Custom favicon URL

  // Relations
  members                TenantMember[]
  apiKeys                ApiKey[]
  subscriptions          Subscription[]
  mediaFolders           MediaFolder[]
  media                  Media[]
  apiTokens              ApiToken[]
  webhooks               Webhook[]
  contentTypeAssignments TenantContentTypeAssignment[]
  singleTypeAssignments  TenantSingleTypeAssignment[]
  componentAssignments   TenantComponentAssignment[]
  rolePermissions        RolePermission[]
  locales                TenantLocale[]
  contentEntries         ContentEntry[]
  contentTypes           ContentType[]
  singleTypes            SingleType[]
  components             Component[]
  auditLogs              AuditLog[]
  settings               Setting[]
  apiRequests            ApiRequest[]

  @@map("tenants")
}

model TenantMember {
  id       String   @id @default(cuid())
  tenantId String
  userId   String
  role     String   @default("member") // owner, admin, editor, viewer
  joinedAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@map("tenant_members")
}

// ==================== CONTENT TYPES (Global - Created by Super Admin) ====================

model ContentType {
  id          String   @id @default(cuid())
  tenantId    String? // Null means it's a system/global template, non-null means it belongs to a startup
  name        String
  slug        String
  description String?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  tenant  Tenant?                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fields  ContentTypeField[]
  entries ContentEntry[]
  tenants TenantContentTypeAssignment[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("content_types")
}

model ContentTypeField {
  id            String  @id @default(cuid())
  contentTypeId String
  name          String
  slug          String
  type          String // text, textarea, richText, integer, decimal, biginteger, float, date, time, datetime, timestamp, enumeration, select, boolean, email, password, uid, media, mediaMultiple, relation, component, json, color, location
  required      Boolean @default(false)
  unique        Boolean @default(false)
  localizable   Boolean @default(true) // Can this field be translated per locale?
  options       Json? // Native JSON for field options
  jsonPath      String? // API path for dynamic options (e.g., "/api/categories")
  relationSlug  String? // Slug of related single type for relation fields
  order         Int     @default(0)

  contentType ContentType @relation(fields: [contentTypeId], references: [id], onDelete: Cascade)

  @@unique([contentTypeId, slug])
  @@map("content_type_fields")
}

// Tenant-ContentType Assignment (which tenants can use which content types)
model TenantContentTypeAssignment {
  id            String   @id @default(cuid())
  tenantId      String
  contentTypeId String
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contentType ContentType @relation(fields: [contentTypeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, contentTypeId])
  @@map("tenant_content_type_assignments")
}

// ==================== CONTENT STATUS WORKFLOW ====================

enum ContentStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  SCHEDULED
  PUBLISHED
  ARCHIVED
  REJECTED
}

model ContentEntry {
  id            String                   @id @default(cuid())
  documentId    String? // Group translations of the same entry
  contentTypeId String
  tenantId      String // Each tenant has their own entries
  locale        String                   @default("en") // i18n locale
  data          Json // Native JSON for entry data
  status        ContentStatus            @default(DRAFT)
  reviewComment String? // Comment from reviewer on reject/approve
  publishedAt   DateTime?
  scheduledAt   DateTime? // When to auto-publish (used with SCHEDULED status)
  archivedAt    DateTime? // When the entry was archived
  searchVector  Unsupported("tsvector")? // Full-text search vector
  createdBy     String?
  updatedBy     String?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  contentType       ContentType               @relation(fields: [contentTypeId], references: [id], onDelete: Cascade)
  tenant            Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  versions          ContentVersion[]
  reviewAssignments ContentReviewAssignment[]

  @@index([documentId])
  @@index([tenantId, contentTypeId, status])
  @@index([tenantId, locale])
  @@index([status, scheduledAt])
  @@index([tenantId, status])
  @@map("content_entries")
}

// Content versioning - stores history of all changes
model ContentVersion {
  id             String    @id @default(cuid())
  contentEntryId String
  version        Int // Auto-incremented version number
  data           Json // Native JSON snapshot of entry data at this version
  publishedAt    DateTime?
  changeType     String // created, updated, published, unpublished
  changedBy      String? // User ID who made the change
  changeSummary  String? // Optional description of what changed
  createdAt      DateTime  @default(now())

  contentEntry ContentEntry @relation(fields: [contentEntryId], references: [id], onDelete: Cascade)

  @@unique([contentEntryId, version])
  @@index([contentEntryId, createdAt])
  @@map("content_versions")
}

// ==================== MULTI-REVIEWER APPROVAL ====================

model ContentReviewAssignment {
  id             String    @id @default(cuid())
  contentEntryId String
  reviewerId     String // User ID of the reviewer
  reviewerName   String? // Denormalized for display
  order          Int       @default(0) // Review sequence (0 = first reviewer)
  status         String    @default("pending") // pending, approved, rejected
  comment        String?
  reviewedAt     DateTime?
  assignedBy     String? // User ID who assigned this reviewer
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  contentEntry ContentEntry @relation(fields: [contentEntryId], references: [id], onDelete: Cascade)

  @@unique([contentEntryId, reviewerId])
  @@index([reviewerId, status])
  @@map("content_review_assignments")
}

// ==================== SINGLE TYPES (Global - Created by Super Admin) ====================

model SingleType {
  id          String   @id @default(cuid())
  tenantId    String? // Null means it's a system/global template
  name        String
  slug        String
  description String?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  tenant  Tenant?                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fields  SingleTypeField[]
  tenants TenantSingleTypeAssignment[]

  @@unique([tenantId, slug])
  @@map("single_types")
}

model SingleTypeField {
  id           String  @id @default(cuid())
  singleTypeId String
  name         String
  slug         String
  type         String // text, textarea, richText, integer, decimal, biginteger, float, date, time, datetime, timestamp, enumeration, select, boolean, email, password, uid, media, mediaMultiple, relation, component, json, color, location
  required     Boolean @default(false)
  unique       Boolean @default(false)
  localizable  Boolean @default(true) // Can this field be translated per locale?
  options      Json? // Native JSON for field options
  jsonPath     String? // API path for dynamic options (e.g., "/api/categories")
  relationSlug String? // Slug of related single type for relation fields
  order        Int     @default(0)

  singleType SingleType @relation(fields: [singleTypeId], references: [id], onDelete: Cascade)

  @@unique([singleTypeId, slug])
  @@map("single_type_fields")
}

// Tenant-SingleType Assignment
model TenantSingleTypeAssignment {
  id           String    @id @default(cuid())
  tenantId     String
  singleTypeId String
  locale       String    @default("en")
  enabled      Boolean   @default(true)
  data         Json? // Native JSON for tenant-specific content data
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  singleType SingleType @relation(fields: [singleTypeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, singleTypeId, locale])
  @@map("tenant_single_type_assignments")
}

// ==================== COMPONENTS (Global - Created by Super Admin) ====================

model Component {
  id          String   @id @default(cuid())
  tenantId    String? // Null means global
  name        String
  slug        String
  description String?
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  tenant  Tenant?                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fields  ComponentField[]
  tenants TenantComponentAssignment[]

  @@unique([tenantId, slug])
  @@map("components")
}

model ComponentField {
  id           String  @id @default(cuid())
  componentId  String
  name         String
  slug         String
  type         String // text, textarea, richText, integer, decimal, biginteger, float, date, time, datetime, timestamp, enumeration, select, boolean, email, password, uid, media, mediaMultiple, relation, component, json, color, location
  required     Boolean @default(false)
  unique       Boolean @default(false)
  localizable  Boolean @default(true) // Can this field be translated per locale?
  options      Json? // Native JSON for field options
  jsonPath     String? // API path for dynamic options (e.g., "/api/categories")
  relationSlug String? // Slug of related single type for relation fields
  order        Int     @default(0)

  component Component @relation(fields: [componentId], references: [id], onDelete: Cascade)

  @@unique([componentId, slug])
  @@map("component_fields")
}

// Tenant-Component Assignment
model TenantComponentAssignment {
  id          String   @id @default(cuid())
  tenantId    String
  componentId String
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  component Component @relation(fields: [componentId], references: [id], onDelete: Cascade)

  @@unique([tenantId, componentId])
  @@map("tenant_component_assignments")
}

// ==================== API KEYS ====================

model ApiKey {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  key         String    @unique
  permissions Json? // Native JSON for permissions
  lastUsed    DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

// ==================== SUBSCRIPTIONS & BILLING ====================

model Subscription {
  id                     String    @id @default(cuid())
  userId                 String
  tenantId               String?
  plan                   String // free, starter, pro, enterprise
  status                 String    @default("active") // active, canceled, expired
  midtransCustomerId     String?
  midtransSubscriptionId String?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean   @default(false)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant              Tenant?              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoices            Invoice[]
  paymentTransactions PaymentTransaction[]

  @@map("subscriptions")
}

model Invoice {
  id                String    @id @default(cuid())
  subscriptionId    String
  amount            Float
  currency          String    @default("IDR")
  status            String    @default("pending") // pending, paid, failed
  midtransInvoiceId String?
  paidAt            DateTime?
  createdAt         DateTime  @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@map("invoices")
}

model PaymentTransaction {
  id              String    @id @default(cuid())
  subscriptionId  String?
  invoiceId       String?
  orderId         String    @unique // Midtrans order ID
  paymentType     String? // gopay, bank_transfer, credit_card, qris, etc.
  paymentMethod   String? // Specific channel (gopay_qris, bca_va, mandiri_bill, etc.)
  amount          Float
  status          String // pending, success, failed, cancelled, refund
  transactionId   String? // Midtrans transaction ID
  transactionTime DateTime?
  fraudStatus     String?
  rawResponse     Json? // Native JSON response from Midtrans
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  @@map("payment_transactions")
}

// ==================== AUDIT LOGS ====================

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String?
  userId    String?
  action    String
  entity    String
  entityId  String?
  data      Json? // Native JSON data
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

// ==================== SYSTEM SETTINGS ====================

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  tenantId  String? // null for global settings
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("settings")
}

// ==================== MONITORING ====================

model SystemMetric {
  id        String   @id @default(cuid())
  type      String // cpu, memory, requests, errors
  value     Float
  metadata  Json? // Native JSON metadata
  timestamp DateTime @default(now())

  @@map("system_metrics")
}

model ApiRequest {
  id         String   @id @default(cuid())
  tenantId   String?
  endpoint   String
  method     String
  statusCode Int
  duration   Int // milliseconds
  apiKeyId   String?
  createdAt  DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("api_requests")
}

// ==================== MEDIA LIBRARY ====================

model MediaFolder {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  path      String // e.g. /images/banners
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   MediaFolder?  @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children MediaFolder[] @relation("FolderHierarchy")
  media    Media[]

  @@unique([tenantId, path])
  @@map("media_folders")
}

model Media {
  id           String   @id @default(cuid())
  tenantId     String
  folderId     String?
  name         String
  originalName String
  mimeType     String
  size         Int // in bytes
  url          String
  storageKey   String? // S3/R2 object key (e.g., tenantId/2026/03/uuid.jpg)
  thumbnailUrl String?
  mediumUrl    String? // Medium-size image URL (600px)
  alt          String?
  caption      String?
  width        Int?
  height       Int?
  isPrivate    Boolean  @default(false)
  metadata     Json? // Native JSON for additional metadata
  uploadedBy   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  folder MediaFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([tenantId, mimeType])
  @@map("media")
}

// ==================== RBAC (Role-Based Access Control) ====================

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique // e.g. content-type.read, content-type.create, media.upload
  displayName String
  description String?
  category    String // content, media, users, settings, api
  createdAt   DateTime @default(now())

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(cuid())
  tenantId     String? // Keep for reference but logically unused now
  roleId       String // e.g. "admin", "editor"
  permissionId String
  granted      Boolean  @default(true)
  createdAt    DateTime @default(now())

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  tenant     Tenant?    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, roleId, permissionId])
  @@map("role_permissions")
}

// ==================== API TOKENS (Strapi-like) ====================

model ApiToken {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  description String?
  token       String    @unique
  type        String    @default("read-only") // read-only, full-access, custom
  permissions Json? // Native JSON array of permission names
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("api_tokens")
}

// ==================== WEBHOOKS ====================

model Webhook {
  id              String    @id @default(cuid())
  tenantId        String
  name            String
  url             String
  secret          String? // For signature verification
  events          Json // Native JSON array of event types
  headers         Json? // Native JSON object for custom headers
  enabled         Boolean   @default(true)
  hookType        String    @default("async") // async or sync (before* hooks are sync)
  lastTriggeredAt DateTime?
  failureCount    Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  logs        WebhookLog[]
  deadLetters WebhookDeadLetter[]

  @@map("webhooks")
}

model WebhookLog {
  id         String   @id @default(cuid())
  webhookId  String
  event      String
  payload    Json // Native JSON payload
  response   Json? // Native JSON response body
  statusCode Int?
  success    Boolean
  duration   Int? // milliseconds
  error      String?
  createdAt  DateTime @default(now())

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@map("webhook_logs")
}

// Dead Letter Queue for failed webhook deliveries
model WebhookDeadLetter {
  id          String    @id @default(cuid())
  webhookId   String
  event       String
  payload     Json // Native JSON payload
  lastError   String?
  attempts    Int       @default(0)
  maxAttempts Int       @default(5)
  nextRetryAt DateTime?
  status      String    @default("pending") // pending, retrying, exhausted, replayed
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([status, nextRetryAt])
  @@index([webhookId])
  @@map("webhook_dead_letters")
}

// ==================== I18N LOCALES ====================

model TenantLocale {
  id        String  @id @default(cuid())
  tenantId  String
  locale    String // e.g. "en", "id", "ja"
  name      String // e.g. "English", "Bahasa Indonesia"
  isDefault Boolean @default(false)
  isEnabled Boolean @default(true)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, locale])
  @@map("tenant_locales")
}
